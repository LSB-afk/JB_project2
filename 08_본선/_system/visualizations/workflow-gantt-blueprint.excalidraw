      "x": 40,
      "y": 18,
      "width": 980,
      "height": 36,
      "text": "전체 워크플로 간트차트 — 심사기준·담당자·AI 에이전트 추적형",
      "fontSize": 22,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 28,
      "containerId": null,
      "originalText": "전체 워크플로 간트차트 — 심사기준·담당자·AI 에이전트 추적형",
      "lineHeight": 1.25
    },
    {
      "id": "viz-2",
      "angle": 0,
      "strokeColor": "#1e293b",
